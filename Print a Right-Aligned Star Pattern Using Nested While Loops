#include<stdio.h>
int main(){
    
    int i,j;
    
    i=1;
    
    while(i<=5){
        j=1;
        while(j<= 5 - i){
            printf(" ");
            j+=1;
        }
        j=1;
        while(j<=i){
            printf("x");
            j+=1;
        }
        printf("\n");
        
        i+=1;
    }
}
